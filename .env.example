# Copy this file to .env and fill in real values. Never commit .env to git.

# Pooled connection (transaction mode) - used by the app at runtime.
# Get this from Supabase: Connect button -> ORM tab -> Prisma
DATABASE_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-1-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (session mode) - used only for migrations (prisma db push / migrate).
DIRECT_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-1-[region].pooler.supabase.com:5432/postgres"

# WhatsApp number for the quote redirect (no symbols, country code first)
# 014-9496354 -> 60149496354
NEXT_PUBLIC_WHATSAPP_NUMBER="60149496354"
